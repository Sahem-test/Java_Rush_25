    Обычный массив:

 int[] scores = new int[10];
for (int i = 0; i < scores.length; i++)
{
    int score = scores[i];
    System.out.println("Баллы: " + score);
}

for-each

for (int score : scores)
{
    System.out.println("Баллы: " + score);
}
